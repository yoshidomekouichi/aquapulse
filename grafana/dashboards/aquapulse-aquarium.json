        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "aquapulse_mock" },
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "WITH hourly AS (SELECT date_trunc('hour', time) as hour, MIN(value) as min_temp, MAX(value) as max_temp FROM sensor_readings WHERE sensor_id LIKE 'ds18b20%' AND metric = 'temperature' AND time > NOW() - INTERVAL '24 hours' GROUP BY 1) SELECT hour as \"時間\", ROUND(min_temp::numeric, 2) as \"最低\", ROUND(max_temp::numeric, 2) as \"最高\", ROUND((max_temp - min_temp)::numeric, 2) as \"変化量\" FROM hourly ORDER BY hour DESC LIMIT 12",
