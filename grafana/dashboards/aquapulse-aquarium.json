        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "aquapulse_mock" },
            "editorMode": "code",
            "format": "time_series",
            "rawQuery": true,
            "rawSql": "WITH temp_data AS (SELECT time, value, LAG(value) OVER (ORDER BY time) as prev_value, LAG(time) OVER (ORDER BY time) as prev_time FROM sensor_readings WHERE sensor_id LIKE 'ds18b20%' AND metric = 'temperature' AND $__timeFilter(time)) SELECT time, CASE WHEN prev_time IS NOT NULL AND EXTRACT(EPOCH FROM time - prev_time) > 0 THEN ROUND(((value - prev_value) / (EXTRACT(EPOCH FROM time - prev_time) / 3600))::numeric, 3) ELSE 0 END as \"変化速度\" FROM temp_data WHERE prev_time IS NOT NULL ORDER BY time",
            "refId": "A"
          }
        ],
        "title": "⚡ 水温変化速度 (°C/時間)",
        "type": "timeseries"
      },
