            "rawSql": "WITH water AS (SELECT date_trunc('hour', time) as hour, AVG(value) as temp FROM sensor_readings WHERE sensor_id LIKE 'ds18b20%' AND metric = 'temperature' AND time > NOW() - INTERVAL '24 hours' GROUP BY 1), room AS (SELECT date_trunc('hour', time) as hour, AVG(value) as temp FROM sensor_readings WHERE sensor_id LIKE 'tapo_%' AND metric = 'temperature' AND time > NOW() - INTERVAL '24 hours' GROUP BY 1) SELECT ROUND(CORR(w.temp, r.temp)::numeric, 2) as \"相関係数\" FROM water w JOIN room r ON w.hour = r.hour",
            "refId": "A"
          }
        ],
        "title": "📊 水温-室温 相関係数",
        "type": "stat"
