# ========================================
# AquaPulse 環境変数設定テンプレート
# ========================================
# このファイルを `.env` にコピーして使用してください
# 値を実際の環境に合わせて設定してください

# ========================================
# データベース設定（必須）
# ========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=aquapulse

# ========================================
# データソース設定（必須）
# ========================================
# 有効にするデータソースをカンマ区切りで指定
# 例: gpio_temp,gpio_tds,tapo_sensors,tapo_lighting
# テスト時: mock
SOURCES=gpio_temp,tapo_sensors,tapo_lighting

# ========================================
# Tapo デバイス認証（必須 - Tapo使用時）
# ========================================
# Tapoアプリで使用しているメールアドレスとパスワード
TAPO_USERNAME=your_tapo_email@example.com
TAPO_PASSWORD=your_tapo_password

# ========================================
# Tapo デバイスIP設定（推奨）
# ========================================
# H100 ハブの固定IP（温湿度センサー T310/T315用）
TAPO_HUB_IP=192.168.3.6

# P300 マルチタップの固定IP（照明ON/OFF用）
# 注意: H100とは別デバイスです！
TAPO_LIGHTING_IP=192.168.3.8

# ========================================
# Tapo バックエンド選択（オプション）
# ========================================
# tapo_sensorsで使用するライブラリ
# python-kasa（デフォルト）または tapo
# デフォルト: python-kasa
TAPO_BACKEND=python-kasa

# ========================================
# IPローラー作戦（オプション）
# ========================================
# DHCP環境でIPが変動する場合に複数のIPを試行
# 設定しない場合は 192.168.3.2~12 を順に試行
# TAPO_IP_CANDIDATES=192.168.3.6,192.168.3.7,192.168.3.8

# ========================================
# GPIO 水温センサー設定（オプション）
# ========================================
# DS18B20 水温センサーの収集間隔（分）
# デフォルト: 1分
GPIO_TEMP_INTERVAL=1

# ========================================
# TDS センサー設定（オプション）
# ========================================
# TDS測定間隔（秒） - 常時測定時
# デフォルト: 60秒
TDS_INTERVAL=60

# TDSセンサーのID
# 本番: tds_ch1, テスト: tds_test_ch1, 瓶測定: tds_bottle
# デフォルト: tds_ch1
TDS_SENSOR_ID=tds_ch1

# 電圧→ppm変換係数（キャリブレーション用）
# デフォルト: 500
TDS_K=500

# ========================================
# 収集間隔設定（オプション）
# ========================================
# 全センサー共通の収集間隔（秒）
# 各センサー個別の設定が優先されます
# SAMPLE_INTERVAL=60

# ========================================
# 開発・デバッグ用（オプション）
# ========================================
# ログレベル: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# 通知設定（将来実装予定）
# NOTIFY_EMAIL=
# NOTIFY_SLACK_WEBHOOK=
